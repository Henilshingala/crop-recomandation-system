# =============================================================================
# Crop Recommendation System - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment

# SECURITY: Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production-immediately
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-production-domain.com,localhost,127.0.0.1

# CORS Settings (comma-separated list of allowed origins - NO WILDCARDS)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# Database (PostgreSQL recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/crop_db
# DB_PASSWORD=your_secure_password

# HuggingFace ML Gateway
HF_MODEL_URL=https://shingala-crs.hf.space
# HF_TOKEN=your-token-if-space-is-private  # Optional

# AI/ML Model Directory Path (Optional, defaults to ../../AiMl relative to Backend/app)
# AI_ML_DIR=/path/to/your/AiMl

# PostgreSQL Database Configuration (Optional, if using SQLlite, these can be ignored)
# DB_NAME=crop_recommendation_db
# DB_USER=postgres
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432
